# Quellgeist environment — copy to `.env` and fill in. NEVER commit `.env`.
# The repo is public (DR-0023 Q21): every secret is env-only. `.env*` is gitignored;
# only this `.env.example` (placeholders, no secrets) is committed.

# --- reasoner (v1 + v2) ---------------------------------------------------------
# Any LiteLLM model string. Hosted = easiest; local Ollama = $0/offline.
QG_MODEL=ollama_chat/qwen3:4b-instruct-2507-q4_K_M
# Provider key for a hosted QG_MODEL (choose the one matching your model). Leave the
# others unset. Read by LiteLLM from the environment; never stored in the repo.
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=

# Optional: pin the verifier/judge model separately (must NOT equal QG_MODEL for a
# real measurement — the tuned model must not verify itself; DR-0016).
# QG_VERIFIER_MODEL=
# QG_JUDGE_MODEL=

# --- signal sources (v1 CLI + v2 per-incident snapshots) ------------------------
# Point these at your canonical files, or run `quellgeist ingest` to produce them.
# QG_LOG_PATH=./signals/incident_logs.jsonl
# QG_DEPLOY_LOG=./signals/deploy_log.json
# QG_METRICS_PATH=./signals/metrics.json
# Real-data guardrails (DR-0022): 0 = uncapped.
# QG_MAX_ROWS=200
# QG_MAX_POINTS=1000

# --- v2 service (Wave 7+) -------------------------------------------------------
# Directory the service snapshots each incident's signals into (per-incident isolation).
QG_SIGNALS_DIR=./var/signals
# SQLite store (WAL). Created on first run.
QG_DB_PATH=./var/quellgeist.db
# HMAC signing secret for the inbound webhook — REQUIRED for the service; any random
# high-entropy string shared with the webhook sender. Requests are rejected without it.
QG_WEBHOOK_SECRET=
# Slack incoming-webhook URL for posting diagnoses (the only new outbound egress).
QG_SLACK_WEBHOOK_URL=

# --- v2 Wave 8: HITL / output ---------------------------------------------------
# Bearer token for the operator surface (GET /incidents/{id} page + status + review).
# REQUIRED to use the operator endpoints — unset => they are fail-closed (rejected).
QG_OPERATOR_TOKEN=
# Where approved postmortem HTML artifacts are written.
QG_HTML_DIR=./var/postmortems
# NOTE: QG_VERIFIER_MODEL (above) is now load-bearing for the LIVE path — the review gate
# refuses to post an UNVERIFIED run, and it must differ from QG_MODEL (DR-0016).
# Webhook replay window: >0 => require a fresh X-Quellgeist-Timestamp (unix secs) within N
# seconds, bound into the HMAC. 0 = disabled (no timestamp required).
QG_WEBHOOK_MAX_SKEW_S=0

# --- v2 service tuning (optional; safe defaults) --------------------------------
# QG_WORKERS=2            # worker pool size (>=1)
# QG_QUEUE_MAXSIZE=1000   # bounded queue -> backpressure (>=1)
# QG_MAX_BODY_BYTES=1000000  # webhook body cap in bytes (>=1)

# --- free-tier pacing (optional) ------------------------------------------------
# Minimum seconds between model calls, to stay under a provider's requests-per-minute
# ceiling on a multi-call eval (DR-0015). 0 = off.
# QG_MIN_CALL_INTERVAL_S=0
