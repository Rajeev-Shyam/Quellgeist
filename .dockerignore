# Keep the build context small + never leak local state / secrets into an image layer.
.git
.github
.venv
.venv-finetune
**/__pycache__
*.py[cod]
*.egg-info
build
dist

# Local runtime + secrets (env-only; never in an image)
.env
.env.*
!.env.example
var
runs
*.db
*.log

# Not needed by the runtime image (docs / evals / training / fine-tune / MCP manifests)
docs
evals
finetune
mcp
tests

# Local demo artifacts (regenerated by the chaos scripts inside the container)
demo/incident_logs.jsonl
demo/deploy_log.json
demo/.bad_deploy

# Caches / editor / OS cruft
.pytest_cache
.ruff_cache
.mypy_cache
.DS_Store
